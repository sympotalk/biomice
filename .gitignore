# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# claude code
.claude/settings.local.json
.claude/worktrees/
.claude/session.log
.claude/.cache/

# claude code 자동화 — 배포 기록 중 시크릿 포함 가능 파일은 제외
docs/deployments/*-secrets.md

# CLAUDE.md / 기타 백업 파일
*.backup

# vercel
.vercel

# opennext / cloudflare wrangler
.open-next/
.wrangler/
cloudflare-env.d.ts

# typescript
*.tsbuildinfo
next-env.d.ts
.tmp_fetch/
