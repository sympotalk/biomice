{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "_description": "biomice 프로젝트 — Claude Code 권한 + 훅 설정. 사용자별 로컬 권한은 settings.local.json (gitignore).",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git rebase origin/main)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin HEAD)",
      "Bash(git stash*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh release*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npm run preview*)",
      "Bash(npm run cf-typegen*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm test*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx wrangler tail*)",
      "Bash(npx wrangler deployments*)",
      "Bash(npx wrangler whoami)",
      "Bash(npx supabase gen*)",
      "Bash(node -e *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(date)",
      "Bash(pwd)",
      "Read(**)",
      "Write(./.claude/**)",
      "Write(./docs/**)",
      "Write(./src/**)",
      "Write(./public/**)",
      "Write(./.github/**)",
      "Write(./README.md)",
      "Write(./CLAUDE.md)",
      "Write(./AGENTS.md)",
      "Write(./STATE.md)",
      "Write(./PROJECT.md)",
      "Write(./MOBILE_REDESIGN_BRIEF.md)",
      "Write(./tsconfig.json)",
      "Write(./eslint.config.mjs)",
      "Write(./next.config.ts)",
      "Write(./postcss.config.mjs)",
      "Write(./wrangler.jsonc)",
      "Write(./open-next.config.ts)",
      "Write(./.gitignore)",
      "Edit(**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf node_modules*)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(chmod 777 *)",
      "Bash(npx wrangler secret put *)",
      "Bash(npx wrangler secret delete *)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.*.local)",
      "Read(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.production)",
      "Write(./.env.*.local)",
      "Write(./secrets/**)",
      "Write(./node_modules/**)",
      "Write(./.next/**)",
      "Write(./.open-next/**)",
      "Write(./.wrangler/**)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.production)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(git tag -d *)",
      "Bash(git revert *)",
      "Bash(npm publish*)",
      "Bash(npm run deploy*)",
      "Bash(npx wrangler deploy*)",
      "Bash(npx wrangler delete*)",
      "Bash(npx wrangler rollback*)",
      "Bash(rm -rf src*)",
      "Bash(rm -rf docs*)",
      "Bash(rm -rf .claude*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"eslint.config.mjs\" ] && command -v npx > /dev/null 2>&1; then npx --no -- eslint --fix \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] session stopped\" >> .claude/session.log"
          }
        ]
      }
    ]
  }
}
